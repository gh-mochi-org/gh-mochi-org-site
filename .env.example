# Admin Authentication
# Generate a secure random string for this (e.g., openssl rand -hex 32)
ADMIN_SECRET=gh-mochi-admin-secret

# Database (Neon PostgreSQL)
NEON_DB_CONNECTION_STRING=postgresql://user:password@host/database

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@gh-mochi.org

# Discord Notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Optional: separate webhooks for specific channels
DISCORD_GH_MOCHI_UPDATES_NEWS_ANNOUNCEMENT_CHANNEL_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_GH_MOCHI_NEW_PROJECT_ANNOUNCEMENT_CHANNEL_WEBHOOK=https://discord.com/api/webhooks/...

# Crypto Wallet Addresses
# Add your wallet addresses below. Leave blank if you don't want to display a coin.
BTC_WALLET_ADDR=
ETH_WALLET_ADDR=
USDT_WALLET_ADDR=
USDC_WALLET_ADDR=
XMR_WALLET_ADDR=
SOL_WALLET_ADDR=

# Helio Payment API (optional)
# HELIO_API_KEY=your_helio_api_key_here
# HELIO_PUBLIC_KEY=your_helio_public_key_here
# HELIO_NETWORK=test or main

# Cloudflare Turnstile (optional)
CF_SITE_KEY_SECRET=your_cf_secret_key_here

