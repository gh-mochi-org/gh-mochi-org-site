# Admin Authentication
# Generate a secure random string for this (e.g., openssl rand -hex 32)
ADMIN_SECRET=your_admin_password_here

# Database (Neon PostgreSQL)
NEON_DB_CONNECTION_STRING=postgresql://user:password@host/database

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Discord Notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Hel.io Payment (Mainnet)
HELIO_SECRET_KEY=your_helio_secret_key_here
HELIO_PUBLIC_KEY=your_helio_public_key_here
HELIO_NETWORK=main

# Wallet IDs (from Helio dashboard)
HELIO_WALLET_USDT=your_usdt_wallet_id
HELIO_WALLET_BTC=your_btc_wallet_id
HELIO_WALLET_SOL=your_sol_wallet_id
PUBLIC_CF_TURNSTILE_SITE_KEY=....
